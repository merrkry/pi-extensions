{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "target": "ES2024",
    "lib": ["ES2024"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "exactOptionalPropertyTypes": false,
    "noUncheckedIndexedAccess": false,
    "paths": {
      "#src/*": ["./src/*"],
      "#test/*": ["./test/*"]
    }
  },
  "include": ["src/**/*.ts", "test/**/*.ts"]
}
